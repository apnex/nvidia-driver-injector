diff --git a/kernel-open/nvidia/os-pci.c b/kernel-open/nvidia/os-pci.c
index 4190c59..70bf34f 100644
--- a/kernel-open/nvidia/os-pci.c
+++ b/kernel-open/nvidia/os-pci.c
@@ -147,6 +147,45 @@ void NV_API_CALL os_pci_remove(
     pci_stop_and_remove_bus_device(handle);
 }
 
+//
+// Disconnected-device helpers used by the GPU-lost crash-safety
+// cascade in src/nvidia/arch/nvalloc/unix/src/os.c. Keep <linux/pci.h>
+// confined to kernel-open so RM-side code (os.c) only needs the
+// generic os_pci_* prototypes from os-interface.h.
+//
+// Crash-safety guard; see docs/lever-catalog.md.
+//
+NvBool NV_API_CALL os_pci_is_disconnected(
+    void *handle
+)
+{
+    struct pci_dev *pdev = (struct pci_dev *) handle;
+    if (!pdev)
+        return NV_FALSE;
+    return pci_dev_is_disconnected(pdev) ? NV_TRUE : NV_FALSE;
+}
+
+void NV_API_CALL os_pci_set_disconnected(
+    void *handle
+)
+{
+    struct pci_dev *pdev = (struct pci_dev *) handle;
+    if (!pdev)
+        return;
+    //
+    // pci_channel_io_perm_failure is a sink state — once set, no
+    // transitions out — so a non-atomic WRITE_ONCE is race-safe even
+    // if AER is concurrently transitioning the device through other
+    // states. The kernel's own pci_dev_is_disconnected() inline reads
+    // via READ_ONCE, so this matches the kernel's pattern.
+    //
+    // Linux 6.x has pci_dev_set_io_state() in drivers/pci/pci.c but
+    // it is private (not exported). Reproducing the relevant write
+    // here is the cleanest module-friendly equivalent.
+    //
+    WRITE_ONCE(pdev->error_state, pci_channel_io_perm_failure);
+}
+
 NV_STATUS NV_API_CALL
 os_enable_pci_req_atomics(
     void *handle,
diff --git a/src/nvidia/arch/nvalloc/unix/include/nv-tb-egpu.h b/src/nvidia/arch/nvalloc/unix/include/nv-tb-egpu.h
new file mode 100644
index 0000000..64f2bf5
--- /dev/null
+++ b/src/nvidia/arch/nvalloc/unix/include/nv-tb-egpu.h
@@ -0,0 +1,77 @@
+/*
+ * SPDX-FileCopyrightText: nvidia-driver-injector contributors
+ * SPDX-License-Identifier: MIT
+ *
+ * tb-egpu crash-safety helpers — shared constants and macros used by
+ * the GPU-lost crash-safety cascade (cluster P1).
+ *
+ * Crash-safety guard; see docs/lever-catalog.md for the full taxonomy
+ * of reliability levers this header backs.
+ *
+ * This header is intentionally self-contained: it only depends on
+ * NV_PRINTF / NV_ASSERT being already in scope at the include site,
+ * so it can be pulled in from anywhere in the RM tree that already
+ * includes the standard utility headers.
+ */
+
+#ifndef _NV_TB_EGPU_H_
+#define _NV_TB_EGPU_H_
+
+/*
+ * Retry policy for osHandleGpuLost. Tuned empirically against the
+ * Thunderbolt-attached eGPU transient PCIe failure window:
+ * 10 * 100us = ~1ms total stall, well below GSP RPC poll cadence.
+ */
+#define TB_EGPU_GPU_LOST_RETRIES        10U
+#define TB_EGPU_GPU_LOST_DELAY_US       100U
+
+/*
+ * Canonical "dead bus" MMIO read return values. A PCIe device that
+ * has fallen off the bus completes config/MMIO reads with all-1s after
+ * the hardware completion timeout (~50ms per read).
+ */
+#define TB_EGPU_DEAD_BUS_U32            0xFFFFFFFFU
+#define TB_EGPU_DEAD_BUS_U16            0xFFFFU
+#define TB_EGPU_DEAD_BUS_U8             0xFFU
+
+/*
+ * Emit an NV_PRINTF exactly once per kernel-module lifetime at the
+ * call site. Replaces the six near-identical
+ *
+ *     static int s_..._logged = 0;
+ *     if (!s_..._logged) { s_..._logged = 1; NV_PRINTF(...); }
+ *
+ * patterns that were duplicated across the legacy GPU-lost cascade.
+ * The latch is function-scope-static, so each call site gets its own
+ * independent latch.
+ */
+#define TB_EGPU_LOG_ONCE(level, fmt, ...)                                      \
+    do {                                                                       \
+        static int _tb_egpu_logged_ = 0;                                       \
+        if (!_tb_egpu_logged_) {                                               \
+            _tb_egpu_logged_ = 1;                                              \
+            NV_PRINTF(level, fmt, ##__VA_ARGS__);                              \
+        }                                                                     \
+    } while (0)
+
+/*
+ * Cleanup-path assert relaxation: NV_OK and NV_ERR_GPU_IN_FULLCHIP_RESET
+ * are the upstream-accepted statuses; NV_ERR_GPU_IS_LOST is also benign
+ * during resource teardown when the GPU has fallen off the bus (the
+ * cleanup is purely host-side bookkeeping at that point).
+ *
+ * Used in place of the
+ *
+ *     NV_ASSERT((status == NV_OK) ||
+ *               (status == NV_ERR_GPU_IN_FULLCHIP_RESET) ||
+ *               (status == NV_ERR_GPU_IS_LOST));
+ *
+ * triplet that the legacy patch series had to repeat at every resserv
+ * cleanup site.
+ */
+#define NV_ASSERT_OR_GPU_LOST(status)                                          \
+    NV_ASSERT(((status) == NV_OK) ||                                           \
+              ((status) == NV_ERR_GPU_IN_FULLCHIP_RESET) ||                    \
+              ((status) == NV_ERR_GPU_IS_LOST))
+
+#endif /* _NV_TB_EGPU_H_ */
