+        }
+        if (retry < (TB_EGPU_GPU_LOST_RETRIES - 1))
+            osDelayUs(TB_EGPU_GPU_LOST_DELAY_US);
+    }
+
     if (pmc_boot_0 != nvp->pmc_boot_0)
