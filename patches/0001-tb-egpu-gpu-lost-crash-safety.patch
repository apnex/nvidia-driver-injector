 }
 
+//
+// Crash-safety guard; see docs/lever-catalog.md.
+//
+// Shared dead-bus predicate used by the 8/16/32-bit osDevReadRegNNN
+// short-circuit (Q-passive). Returns NV_TRUE if either the kernel's
+// PCI layer has marked the device disconnected (e.g. via AER) or the
+// driver itself has declared PDB_PROP_GPU_IS_LOST.
+//
+// Consolidates the three near-identical pGpu/nv/handle/property
+// dances that the legacy patches duplicated across the readers.
+//
+static NV_INLINE NvBool tb_egpu_check_dead_bus(OBJGPU *pGpu)
+{
+    nv_state_t *nv;
+
+    if (pGpu == NULL)
+        return NV_FALSE;
+
+    nv = NV_GET_NV_STATE(pGpu);
+    if (nv != NULL && os_pci_is_disconnected(nv->handle))
+        return NV_TRUE;
+
+    return pGpu->getProperty(pGpu, PDB_PROP_GPU_IS_LOST) ? NV_TRUE : NV_FALSE;
+}
+
 NvU8 osDevReadReg008(
     OBJGPU             *pGpu,
     DEVICE_MAPPING     *pMapping,
@@ -1878,6 +1905,16 @@ NvU8 osDevReadReg008(
 {
     NvU8 retval = 0;
 
+    //
+    // Crash-safety guard (Q-passive); see docs/lever-catalog.md.
+    // 8-bit reads have no vGPU passthrough — they go straight to MMIO,
+    // so they need the same dead-bus short-circuit as the 32-bit path.
+    //
+    if (tb_egpu_check_dead_bus(pGpu))
+    {
+        return TB_EGPU_DEAD_BUS_U8;
+    }
+
     if (thisAddress >= pMapping->gpuNvLength)
     {
         NV_ASSERT(thisAddress < pMapping->gpuNvLength);
@@ -1896,6 +1933,12 @@ NvU16 osDevReadReg016(
 {
     NvU16 retval = 0;
 
+    // Crash-safety guard (Q-passive); see docs/lever-catalog.md.
+    if (tb_egpu_check_dead_bus(pGpu))
+    {
+        return TB_EGPU_DEAD_BUS_U16;
+    }
+
     if (thisAddress >= pMapping->gpuNvLength)
     {
         NV_ASSERT(thisAddress < pMapping->gpuNvLength);
@@ -1921,6 +1964,23 @@ NvU32 osDevReadReg032(
         return retval;
     }
 
+    //
+    // Crash-safety guard (Q-passive); see docs/lever-catalog.md.
+    //
+    // Once either the kernel-level disconnect flag or the driver-level
+    // PDB_PROP_GPU_IS_LOST property is set, every subsequent MMIO read
+    // returns immediately. Without this, each post-loss read would wait
+    // for the PCIe hardware completion timeout (~50ms), saturating the
+    // GPU lock and stalling the host for seconds at a time.
+    //
+    if (tb_egpu_check_dead_bus(pGpu))
+    {
+        TB_EGPU_LOG_ONCE(LEVEL_ERROR,
+            "tb_egpu: osDevReadReg032: dead-bus short-circuit engaged at offset 0x%08x\n",
+            thisAddress);
+        return TB_EGPU_DEAD_BUS_U32;
+    }
+
     if (thisAddress >= pMapping->gpuNvLength)
     {
         NV_ASSERT(thisAddress < pMapping->gpuNvLength);
@@ -1928,6 +1988,51 @@ NvU32 osDevReadReg032(
     else
         retval = NV_PRIV_REG_RD32(pMapping->gpuNvAddr, thisAddress);
 
+    //
+    // Crash-safety guard (Q-active); see docs/lever-catalog.md.
+    //
+    // Post-read sanity check. If the read returned TB_EGPU_DEAD_BUS_U32
+    // the bus may have just died — verify by reading NV_PMC_BOOT_0
+    // directly. If THAT also returns TB_EGPU_DEAD_BUS_U32 (i.e. is the
+    // dead-bus all-1s value, not the saved boot ID), the GPU is
+    // genuinely gone. Declare it lost via gpuSetDisconnectedProperties
+    // (sets PDB_PROP_GPU_IS_LOST so Q-passive short-circuits all
+    // subsequent reads) AND propagate the disconnect state kernel-wide
+    // via os_pci_set_disconnected.
+    //
+    // The verification read uses NV_PRIV_REG_RD32 directly, bypassing
+    // this function to avoid recursion. If the bus is dead, this read
+    // takes one hardware-completion-timeout (~50ms), but happens at
+    // most ONCE per failure event thanks to the LOG_ONCE latch plus
+    // Q-passive intercepting all further reads.
+    //
+    // Note: we compare against TB_EGPU_DEAD_BUS_U32 (all-1s) rather
+    // than against the saved nvp->pmc_boot_0. The legacy comparison
+    // pmc_boot_0_now != nvp->pmc_boot_0 was semantically wrong: if
+    // nvp->pmc_boot_0 was 0 at boot due to a different transient, the
+    // post-read sanity check would false-positive on every healthy
+    // read. The dead-bus value is the canonical signal.
+    //
+    if (retval == TB_EGPU_DEAD_BUS_U32 && pGpu)
+    {
+        nv_state_t *nv = NV_GET_NV_STATE(pGpu);
+        if (nv && nv->regs && nv->regs->map_u &&
+            !pGpu->getProperty(pGpu, PDB_PROP_GPU_IS_LOST))
+        {
+            NvU32 pmc_boot_0_now = NV_PRIV_REG_RD32(nv->regs->map_u, NV_PMC_BOOT_0);
+            if (pmc_boot_0_now == TB_EGPU_DEAD_BUS_U32)
+            {
+                TB_EGPU_LOG_ONCE(LEVEL_ERROR,
+                    "tb_egpu: osDevReadReg032: dead-bus DETECTED via post-read sanity check"
+                    " (trigger_offset=0x%08x, pmc_boot_0=0x%08x);"
+                    " declaring GPU lost\n",
+                    thisAddress, pmc_boot_0_now);
+                gpuSetDisconnectedProperties(pGpu);
+                os_pci_set_disconnected(nv->handle);
+            }
+        }
+    }
+
     return retval;
 }
 
