 NV_STATUS   NV_API_CALL  os_pci_write_dword               (void *, NvU32, NvU32);
 NvBool      NV_API_CALL  os_pci_remove_supported          (void);
 void        NV_API_CALL  os_pci_remove                    (void *);
+//
