+            //
+            NV_GPU_LOST_LOG_ONCE(LEVEL_ERROR,
+                "_threadNodeCheckTimeout: API_GPU_ATTACHED_SANITY_CHECK failed\n");
             return NV_ERR_TIMEOUT;
         }
     }
