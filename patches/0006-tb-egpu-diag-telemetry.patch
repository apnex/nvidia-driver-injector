diff --git a/kernel-open/nvidia/nv-tb-egpu-diag.c b/kernel-open/nvidia/nv-tb-egpu-diag.c
new file mode 100644
index 0000000..233fcd7
--- /dev/null
+++ b/kernel-open/nvidia/nv-tb-egpu-diag.c
@@ -0,0 +1,223 @@
+/*
+ * SPDX-FileCopyrightText: nvidia-driver-injector contributors
+ * SPDX-License-Identifier: MIT
+ *
+ * nv-tb-egpu-diag.c — diagnostic telemetry surface (cluster P6).
+ *
+ * Consolidates legacy 0018 (diag dump core), 0020 (LnkSta/AER
+ * extension), 0021 (Header Log + ASPM + LBMS extension), and the
+ * S2/DIAG-AER2 portion of 0023 (root port AER + DPC) into one rich
+ * per-site state dump.
+ *
+ * Output: one [DIAG] line per call site, with an optional [DIAG-AER]
+ * follow-up line when GPU-side AER status is non-zero, and a [DIAG-AER2]
+ * follow-up with root port AER + DPC state. This separation keeps
+ * clean-boot logs uncluttered while preserving the rich detail when
+ * something actually fired.
+ *
+ * All register reads use module-internal helpers from cluster P2
+ * (tb_egpu_recover_read_wpr2, _walk_to_root_port, _read_dpc_state,
+ * _read_aer_full). Cluster P2's `static` qualifiers on those helpers
+ * were lifted to `extern` in P6 to enable this re-use — file-static
+ * functions made the diag cluster duplicate ~70 lines of register
+ * read patterns it didn't need to. See nv-tb-egpu-recover.h for the
+ * full declarations.
+ *
+ * Per memory feedback_observability_perturbs_bug, even passive
+ * observability can perturb the bug surface. The instrumentation is
+ * called at lifecycle boundaries only (~6 sites per boot + once per
+ * persistenced retry), not in any hot path, so the perturbation risk
+ * is bounded. If a reproduction changes when this lands, A/B verify
+ * via NVreg / Kconfig gating (P7).
+ */
+
+#include "nv-tb-egpu-diag.h"
+#include "nv-tb-egpu-recover.h"
+#include "nv-linux.h"
+
+#include <linux/io.h>       /* ioremap, ioread32, iounmap */
+#include <linux/pci.h>
+#include <linux/pci_regs.h>
+#include <linux/types.h>
+
+void tb_egpu_diag_dump(nv_linux_state_t *nvl, const char *site)
+{
+    nv_state_t     *nv;
+    struct pci_dev *pdev;
+    struct pci_dev *parent;
+    struct pci_dev *root_pdev;
+    u64             bar0_phys;
+    u32             pmc_boot_0 = 0xdeadbeefu;
+    u32             wpr2_raw   = 0xdeadbeefu;
+    void __iomem   *map_pmc;
+    bool            pmc_ok = false;
+    int             wpr2_rc;
+
+    /* GPU/bridge PCIe + AER state. */
+    u16 gpu_lnksta = 0xffff, br_lnksta = 0xffff;
+    u16 gpu_lnkctl = 0xffff, br_lnkctl = 0xffff;
+    int gpu_aer_pos = 0, br_aer_pos = 0;
+    u32 gpu_uesta = 0, gpu_uemsk = 0, gpu_uesvrt = 0, gpu_cesta = 0, gpu_cemsk = 0;
+    u32 gpu_hdrlog[4] = {0, 0, 0, 0};
+    u32 gpu_aer_capctl = 0;
+    u32 br_uesta = 0, br_uemsk = 0, br_uesvrt = 0, br_cesta = 0, br_cemsk = 0;
+
+    /* Root port AER + DPC (DIAG-AER2 expansion). */
+    int  root_aer_pos = 0;
+    u32  root_uesta = 0, root_uemsk = 0, root_uesvrt = 0;
+    u32  root_cesta = 0, root_cemsk = 0;
+    u32  root_rootcmd = 0, root_rootsta = 0, root_errsrc = 0;
+    bool dpc_present = false;
+    u16  dpc_status = 0, dpc_ctl = 0;
+
+    if (!nvl)
+    {
+        nv_printf(NV_DBG_ERRORS,
+            "tb_egpu [DIAG]: site=%s nvl=NULL — cannot read\n", site);
+        return;
+    }
+
+    nv   = NV_STATE_PTR(nvl);
+    pdev = nvl->pci_dev;
+    bar0_phys = nv->bars[NV_GPU_BAR_INDEX_REGS].cpu_address;
+
+    if (bar0_phys == 0)
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "tb_egpu [DIAG]: site=%s bar0_phys=0 — BAR not yet captured; skipping\n",
+            site);
+        return;
+    }
+
+    /* PMC_BOOT_0 — bus-alive canary. */
+    map_pmc = ioremap(bar0_phys, PAGE_SIZE);
+    if (map_pmc)
+    {
+        pmc_boot_0 = ioread32(map_pmc);
+        iounmap(map_pmc);
+        pmc_ok = true;
+    }
+
+    /* WPR2 via the shared P2 helper. */
+    wpr2_rc = tb_egpu_recover_read_wpr2(bar0_phys, &wpr2_raw);
+
+    /* GPU + bridge AER + LnkSta + LnkCtl. */
+    parent    = pdev ? pci_upstream_bridge(pdev) : NULL;
+    root_pdev = pdev ? tb_egpu_recover_walk_to_root_port(pdev) : NULL;
+
+    if (pdev)
+    {
+        (void)pcie_capability_read_word(pdev, PCI_EXP_LNKSTA, &gpu_lnksta);
+        (void)pcie_capability_read_word(pdev, PCI_EXP_LNKCTL, &gpu_lnkctl);
+        tb_egpu_recover_read_aer_full(pdev, &gpu_aer_pos,
+                                      &gpu_uesta, &gpu_uemsk, &gpu_uesvrt,
+                                      &gpu_cesta, &gpu_cemsk,
+                                      gpu_hdrlog, NULL, NULL, NULL);
+        if (gpu_aer_pos)
+        {
+            (void)pci_read_config_dword(pdev, gpu_aer_pos + PCI_ERR_CAP,
+                                        &gpu_aer_capctl);
+        }
+    }
+    if (parent)
+    {
+        (void)pcie_capability_read_word(parent, PCI_EXP_LNKSTA, &br_lnksta);
+        (void)pcie_capability_read_word(parent, PCI_EXP_LNKCTL, &br_lnkctl);
+        tb_egpu_recover_read_aer_full(parent, &br_aer_pos,
+                                      &br_uesta, &br_uemsk, &br_uesvrt,
+                                      &br_cesta, &br_cemsk,
+                                      NULL, NULL, NULL, NULL);
+    }
+    if (root_pdev)
+    {
+        tb_egpu_recover_read_aer_full(root_pdev, &root_aer_pos,
+                                      &root_uesta, &root_uemsk, &root_uesvrt,
+                                      &root_cesta, &root_cemsk,
+                                      NULL,
+                                      &root_rootcmd, &root_rootsta, &root_errsrc);
+        tb_egpu_recover_read_dpc_state(root_pdev, &dpc_present,
+                                       &dpc_status, &dpc_ctl);
+    }
+
+    /* Primary [DIAG] line: PMC_BOOT_0 + WPR2 + LnkSta/LnkCtl + AER status. */
+    NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+        "tb_egpu [DIAG]: site=%-18s bar0=0x%llx "
+        "PMC_BOOT_0=%s%08x WPR2=%s%08x WPR2_up=%s parent=%s "
+        "GPU_LnkSta=0x%04x(Speed=%u Width=x%u Active=%c LBMS=%c LABS=%c) "
+        "GPU_LnkCtl=0x%04x(ASPM=%u ClkPM=%c) "
+        "Br_LnkSta=0x%04x(Speed=%u Width=x%u Active=%c LBMS=%c LABS=%c) "
+        "Br_LnkCtl=0x%04x(ASPM=%u ClkPM=%c) "
+        "GPU_AER_Unc=0x%08x Cor=0x%08x Br_AER_Unc=0x%08x Cor=0x%08x\n",
+        site,
+        (unsigned long long)bar0_phys,
+        pmc_ok ? "0x" : "MAPFAIL:", pmc_boot_0,
+        (wpr2_rc == 0) ? "0x" : "MAPFAIL:", wpr2_raw,
+        ((wpr2_raw & TB_EGPU_RECOVER_WPR2_VAL_MASK) != 0) ? "YES" : "no",
+        parent ? pci_name(parent) : "NULL",
+        gpu_lnksta,
+        (gpu_lnksta & PCI_EXP_LNKSTA_CLS),
+        (gpu_lnksta & PCI_EXP_LNKSTA_NLW) >> 4,
+        (gpu_lnksta & PCI_EXP_LNKSTA_DLLLA) ? 'Y' : 'N',
+        (gpu_lnksta & PCI_EXP_LNKSTA_LBMS) ? '1' : '0',
+        (gpu_lnksta & PCI_EXP_LNKSTA_LABS) ? '1' : '0',
+        gpu_lnkctl,
+        (gpu_lnkctl & PCI_EXP_LNKCTL_ASPMC),
+        (gpu_lnkctl & PCI_EXP_LNKCTL_CLKREQ_EN) ? '1' : '0',
+        br_lnksta,
+        (br_lnksta & PCI_EXP_LNKSTA_CLS),
+        (br_lnksta & PCI_EXP_LNKSTA_NLW) >> 4,
+        (br_lnksta & PCI_EXP_LNKSTA_DLLLA) ? 'Y' : 'N',
+        (br_lnksta & PCI_EXP_LNKSTA_LBMS) ? '1' : '0',
+        (br_lnksta & PCI_EXP_LNKSTA_LABS) ? '1' : '0',
+        br_lnkctl,
+        (br_lnkctl & PCI_EXP_LNKCTL_ASPMC),
+        (br_lnkctl & PCI_EXP_LNKCTL_CLKREQ_EN) ? '1' : '0',
+        gpu_uesta, gpu_cesta, br_uesta, br_cesta);
+
+    /*
+     * [DIAG-AER] follow-up: GPU-side mask, capability/control, and the
+     * Header Log of the first AER-triggering TLP. Only emitted when GPU
+     * AER status is non-zero — keeps clean-boot logs uncluttered.
+     */
+    if (gpu_aer_pos && (gpu_uesta || gpu_cesta))
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "tb_egpu [DIAG-AER]: site=%-18s "
+            "GPU_AER_UncMsk=0x%08x CapCtl=0x%08x "
+            "HdrLog=%08x_%08x_%08x_%08x "
+            "FirstErrPtr=%u\n",
+            site,
+            gpu_uemsk, gpu_aer_capctl,
+            gpu_hdrlog[0], gpu_hdrlog[1], gpu_hdrlog[2], gpu_hdrlog[3],
+            (gpu_aer_capctl & 0x1f));
+    }
+
+    /*
+     * [DIAG-AER2] follow-up: root port AER + DPC + bridge masks. Always
+     * emitted (cheap; one log line). Distinguishes the GPU/bridge view
+     * from the actual host root port — needed because AORUS hub
+     * topologies place a TB hub upstream port between the bridge and
+     * the true root.
+     */
+    NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+        "tb_egpu [DIAG-AER2]: site=%-18s "
+        "Br_UncMsk=0x%08x Br_CorMsk=0x%08x "
+        "Root=%s "
+        "Root_UESta=0x%08x Root_UEMsk=0x%08x Root_CESta=0x%08x Root_CEMsk=0x%08x "
+        "Root_RootSta=0x%08x ErrSrc=0x%08x "
+        "DPC=%s\n",
+        site,
+        br_uemsk, br_cemsk,
+        root_pdev ? pci_name(root_pdev) : "NULL",
+        root_uesta, root_uemsk, root_cesta, root_cemsk,
+        root_rootsta, root_errsrc,
+        dpc_present ? "(see follow-up)" : "absent");
+    if (dpc_present)
+    {
+        NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+            "tb_egpu [DIAG-AER2]: site=%-18s DPC Status=0x%04x Ctl=0x%04x\n",
+            site, dpc_status, dpc_ctl);
+    }
+
+    (void)gpu_uesvrt; (void)br_uesvrt; (void)root_uesvrt; (void)root_rootcmd;
+}
diff --git a/kernel-open/nvidia/nv-tb-egpu-diag.h b/kernel-open/nvidia/nv-tb-egpu-diag.h
new file mode 100644
index 0000000..b47a611
--- /dev/null
+++ b/kernel-open/nvidia/nv-tb-egpu-diag.h
@@ -0,0 +1,52 @@
+/*
+ * SPDX-FileCopyrightText: nvidia-driver-injector contributors
+ * SPDX-License-Identifier: MIT
+ *
+ * nv-tb-egpu-diag.h — diagnostic telemetry surface (cluster P6).
+ *
+ * Companion to the close-path observability cluster (P4). Where P4
+ * captures state at close-side lifecycle points (always-on, load-bearing
+ * for the close-path-bug mitigation), this cluster captures rich
+ * extended state at OPEN-side lifecycle points:
+ *
+ *   - probe-end          end of nv_pci_probe
+ *   - startdev-entry     entry of nv_start_device
+ *   - pre-rmInit         before rm_init_adapter
+ *   - post-rmInit-FAIL   after rm_init_adapter failure
+ *   - post-rmInit-OK     after rm_init_adapter success
+ *
+ * Plus one wired call site in P2's err_handler:
+ *
+ *   - mmio-enabled       inside nv_pci_mmio_enabled
+ *
+ * Captured state per site (one dmesg line, plus an AER-detail line when
+ * AER status is non-zero):
+ *
+ *   PMC_BOOT_0 (BAR0+0) and WPR2 (BAR0+0x88a828) via temporary ioremap;
+ *   PCIe LnkSta + LnkCtl on GPU and parent bridge;
+ *   AER UncStatus / CorStatus on GPU and parent bridge;
+ *   Header Log + UncMask + ASPM + LBMS/LABS bits when AER fired;
+ *   Root port AER + DPC state (the DIAG-AER2 expansion).
+ *
+ * All capture is passive — PCI config-space reads + temporary ioremap.
+ * No DMA, no register writes. Per memory feedback_observability_perturbs_bug,
+ * even passive observability can perturb the bug surface; A/B verify if
+ * your reproduction changes when this lands.
+ *
+ * Default visibility: this cluster currently ships always-on (every
+ * lifecycle point dumps). Kconfig gating (CONFIG_NV_TB_EGPU_DIAG=n by
+ * default) lands in cluster P7 alongside the build-metadata work, per
+ * docs/patch-refactor-status.md.
+ *
+ * See nv-tb-egpu-diag.c for implementation notes.
+ */
+
+#ifndef _NV_TB_EGPU_DIAG_H_
+#define _NV_TB_EGPU_DIAG_H_
+
+struct nv_linux_state_s;
+typedef struct nv_linux_state_s nv_linux_state_t;
+
+void tb_egpu_diag_dump(nv_linux_state_t *nvl, const char *site);
+
+#endif /* _NV_TB_EGPU_DIAG_H_ */
