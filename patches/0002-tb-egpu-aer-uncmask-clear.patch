diff --git a/kernel-open/nvidia/nv-tb-egpu-aer.c b/kernel-open/nvidia/nv-tb-egpu-aer.c
new file mode 100644
index 0000000..df18690
--- /dev/null
+++ b/kernel-open/nvidia/nv-tb-egpu-aer.c
@@ -0,0 +1,131 @@
+/*
+ * SPDX-FileCopyrightText: Copyright (c) 2026 nvidia-driver-injector project
+ * SPDX-License-Identifier: MIT
+ *
+ * Thunderbolt-attached eGPU: AER configuration helpers — cluster P5.
+ *
+ * Single job: at PCI probe, clear the Uncorrectable Error Mask register
+ * on the eGPU so that Internal Errors fire as proper Uncorrectable
+ * Non-Fatal events instead of being silently demoted to Advisory Non-
+ * Fatal (Correctable bit 13).
+ *
+ * Why this matters
+ * ----------------
+ * Per PCIe r6 §6.2.3.2: an Uncorrectable error whose corresponding bit
+ * in the Uncorrectable Error Mask register is set gets downgraded to
+ * Advisory Non-Fatal. UncStatus is NOT updated, Header Log is NOT
+ * captured, and pcie_err_handlers are NOT called.
+ *
+ * On this hardware (AORUS RTX 5090 over TB4), the Linux PCI core +
+ * AORUS BIOS leave UncMask bit 22 (Uncorrectable Internal Error) set
+ * at probe. Every Gen3 probe-end fires Cor=0x2000 (Advisory Non-Fatal
+ * with no Uncor capture and no recovery hook). Clearing the mask lets
+ * the same Internal Errors take the standard AER recovery path: status
+ * latched, Header Log filled, pci_error_handlers fired — which then
+ * lets cluster P2 (Lever M-recover) dispatch its slot_reset/resume
+ * state machine when AER fires.
+ *
+ * The choice "default mask = 0" was discovered by comparing AER
+ * register state against the Windows nvlddmkm driver on the same
+ * hardware (Windows DEVPKEY_PciDevice_Uncorrectable_Error_Mask = 0
+ * observed 2026-05-07). The justification stands on its own merits —
+ * standard PCIe AER recovery requires UncStatus to be latched, which
+ * the mask demotion path bypasses — but the cross-OS comparison was
+ * how we found the regression.
+ *
+ * Independence from P2
+ * --------------------
+ * This file deliberately does NOT depend on the M-recover state machine.
+ * Even on hosts that disable Lever M-recover (NVreg_TbEgpuRecoverEnable=0),
+ * clearing the AER mask is the right default: errors should be visible
+ * in dmesg + lspci AER decode rather than silently demoted. Operators
+ * decide separately whether to enable auto-recovery on top.
+ */
+
+#include "nv-tb-egpu-aer.h"
+
+#include <linux/pci.h>
+#include <linux/pci_regs.h>
+#include <linux/module.h>
+#include <linux/kernel.h>
+
+/* Module parameter: gate the AER mask clear at module load.
+ *
+ * Default-on. Disable with NVreg_TbEgpuAerUncMaskClear=0 if it causes
+ * regression on a specific board. Bool semantics; module_param() takes
+ * uint to avoid the bool kernel-version dance.
+ */
+unsigned int NVreg_TbEgpuAerUncMaskClear = 1;
+module_param(NVreg_TbEgpuAerUncMaskClear, uint, 0644);
+MODULE_PARM_DESC(NVreg_TbEgpuAerUncMaskClear,
+    "Clear AER UncMask at probe so standard recovery handles Internal "
+    "Errors instead of the mask-demotion path (1=on default, 0=leave "
+    "mask as-is)");
+
+/*
+ * Sanity-bound for the AER extended-capability offset.
+ *
+ * PCIe spec puts extended capabilities at offsets >= 0x100 and < 0x1000.
+ * pci_find_ext_capability() returns a value within that range on success
+ * and 0 if absent; we treat any value outside [0x100, 0x1000) as broken
+ * hardware reporting and skip the write to avoid corrupting unrelated
+ * config-space.
+ */
+#define TB_EGPU_AER_OFFSET_MIN  0x100
+#define TB_EGPU_AER_OFFSET_MAX  0x1000
+
+int tb_egpu_aer_clear_uncor_mask(struct pci_dev *pdev)
+{
+    int aer_pos;
+    u32 cur_mask = 0;
+    int rc;
+
+    if (!NVreg_TbEgpuAerUncMaskClear)
+        return 0;
+
+    if (!pdev)
+        return -EINVAL;
+
+    aer_pos = pci_find_ext_capability(pdev, PCI_EXT_CAP_ID_ERR);
+    if (!aer_pos)
+        return 0;  /* device has no AER ext-cap; nothing to do */
+
+    if (aer_pos < TB_EGPU_AER_OFFSET_MIN || aer_pos >= TB_EGPU_AER_OFFSET_MAX)
+    {
+        dev_warn(&pdev->dev,
+            "tb_egpu: AER ext-cap at suspicious offset 0x%x; skipping mask clear\n",
+            aer_pos);
+        return -ERANGE;
+    }
+
+    rc = pci_read_config_dword(pdev, aer_pos + PCI_ERR_UNCOR_MASK, &cur_mask);
+    if (rc)
+    {
+        dev_warn(&pdev->dev,
+            "tb_egpu: AER UncMask read failed (rc=%d); skipping\n", rc);
+        return rc;
+    }
+
+    if (cur_mask == 0)
+    {
+        dev_dbg(&pdev->dev,
+            "tb_egpu: AER UncMask already 0x00000000; no change\n");
+        return 0;
+    }
+
+    rc = pci_write_config_dword(pdev, aer_pos + PCI_ERR_UNCOR_MASK, 0);
+    if (rc)
+    {
+        dev_warn(&pdev->dev,
+            "tb_egpu: AER UncMask write failed (rc=%d); mask left at 0x%08x\n",
+            rc, cur_mask);
+        return rc;
+    }
+
+    dev_info(&pdev->dev,
+        "tb_egpu: AER UncMask 0x%08x -> 0x00000000 "
+        "(Internal Errors now route through standard AER recovery)\n",
+        cur_mask);
+
+    return 0;
+}
