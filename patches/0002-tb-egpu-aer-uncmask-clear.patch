new file mode 100644
index 0000000..3c401e2
--- /dev/null
+++ b/kernel-open/nvidia/nv-tb-egpu-aer.h
@@ -0,0 +1,46 @@
+/*
+ * SPDX-FileCopyrightText: Copyright (c) 2026 nvidia-driver-injector project
+ * SPDX-License-Identifier: MIT
+ *
+ * Thunderbolt-attached eGPU: AER configuration helpers.
+ *
+ * Patch cluster P5 — clears the Uncorrectable Error Mask on the AORUS
+ * RTX 5090 (and similar TB-attached eGPUs) at probe time so that
+ * Uncorrectable Internal Errors fire through the standard AER recovery
+ * flow (pcie_err_handlers) instead of being silently demoted to
+ * Advisory Non-Fatal by the PCIe spec's mask-driven demotion path.
+ *
+ * See docs/lever-catalog.md for the empirical evidence and the
+ * mechanism (PCIe r6 §6.2.3.2 demotion) backing this change.
+ */
+
+#ifndef _NV_TB_EGPU_AER_H_
+#define _NV_TB_EGPU_AER_H_
+
+struct pci_dev;
+
+/**
+ * tb_egpu_aer_clear_uncor_mask - Clear AER Uncorrectable Error Mask.
+ * @pdev: PCI device being probed.
+ *
+ * Reads the device's AER Uncorrectable Error Mask register. If non-zero,
+ * writes 0 — letting Uncorrectable Internal Errors fire as proper
+ * Uncorrectable Non-Fatal events that pcie_err_handlers can react to,
+ * instead of the silent demotion-to-Advisory-Non-Fatal path that the
+ * Linux PCI core + platform firmware leave configured by default.
+ *
+ * No-op when:
+ *  - The module parameter NVreg_TbEgpuAerUncMaskClear is 0.
+ *  - The device does not expose the AER extended capability.
+ *  - The current mask is already zero.
+ *
+ * Safe to call from probe context. Does not require any locks held;
+ * the AER mask is a per-device config-space register and probe is the
+ * only path that touches it.
+ *
+ * Return: 0 on success or no-op; negative errno if the config-space
+ * read or write returns an error (rare; aer_pos is bound-checked).
+ */
+int tb_egpu_aer_clear_uncor_mask(struct pci_dev *pdev);
+
+#endif /* _NV_TB_EGPU_AER_H_ */
