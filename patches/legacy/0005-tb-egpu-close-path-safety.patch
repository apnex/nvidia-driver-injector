 /* -----------------------------------------------------------------------
  * Gate function — single source of truth for the recovery schedule
@@ -1072,3 +1073,156 @@ void tb_egpu_recover_stop(nv_linux_state_t *nvl)
     kfree(st);
     nvl->recover = NULL;
 }
+
+/* =======================================================================
+ * Close-path observability surface (cluster P4).
+ *
+ * Companion to the open-side DIAG infrastructure. Provides:
+ *   - tb_egpu_get_gpu_pdev: cross-module pdev lookup (UVM uses it)
+ *   - tb_egpu_close_diag_pdev: pdev-based passive state capture
+ *   - tb_egpu_close_diag: RM-side close-path marker + last-close dump
+ *
+ * The pdev-based variant exists so nvidia-uvm.ko (which has no
+ * nv_linux_state_t access) can capture the same hardware/firmware
+ * state at UVM close sites. All three are EXPORT_SYMBOL_GPL.
+ *
+ * Passive instrumentation only — ioremap+ioread32 + PCI config-space
+ * reads. No DMA, no register writes.
+ * =======================================================================
+ */
+
+struct pci_dev *tb_egpu_get_gpu_pdev(void)
+{
+    struct pci_dev   *out = NULL;
+    nv_linux_state_t *nvl;
+
+    LOCK_NV_LINUX_DEVICES();
+    for (nvl = nv_linux_devices; nvl != NULL; nvl = nvl->next)
+    {
+        if (nvl->pci_dev)
+        {
+            out = pci_dev_get(nvl->pci_dev);
+            break;
+        }
+    }
+    UNLOCK_NV_LINUX_DEVICES();
+    return out;
+}
+EXPORT_SYMBOL_GPL(tb_egpu_get_gpu_pdev);
+
+void tb_egpu_close_diag_pdev(struct pci_dev *pdev, const char *site)
+{
+    struct pci_dev *parent;
+    u64           bar0_phys;
+    u32           pmc_boot_0 = 0xdeadbeefu;
+    u32           wpr2_raw   = 0xdeadbeefu;
+    int           wpr2_rc;
+    void __iomem *map_pmc;
+    bool          pmc_ok = false;
+    u16 gpu_lnksta = 0xffff, br_lnksta = 0xffff;
+    u32 gpu_aer_unc = 0, gpu_aer_cor = 0;
+    u32 br_aer_unc = 0, br_aer_cor = 0;
+    int gpu_aer_pos = 0, br_aer_pos = 0;
+
+    if (!pdev)
+    {
+        nv_printf(NV_DBG_ERRORS,
+            "tb_egpu [UVM-DIAG]: site=%s pdev=NULL — cannot read\n",
+            site);
+        return;
+    }
+
+    bar0_phys = pci_resource_start(pdev, 0);
+    if (bar0_phys == 0)
+    {
+        nv_printf(NV_DBG_ERRORS,
+            "tb_egpu [UVM-DIAG]: site=%s bar0=0 — skipping\n", site);
+        return;
+    }
+
+    /* PMC_BOOT_0 (BAR0 offset 0). */
+    map_pmc = ioremap(bar0_phys, PAGE_SIZE);
+    if (map_pmc)
+    {
+        pmc_boot_0 = ioread32(map_pmc);
+        iounmap(map_pmc);
+        pmc_ok = true;
+    }
+
+    /* WPR2 via the shared helper extracted in P2. */
+    wpr2_rc = tb_egpu_recover_read_wpr2(bar0_phys, &wpr2_raw);
+
+    /* LnkSta + AER on GPU + bridge (passive config-space reads). */
+    parent = pci_upstream_bridge(pdev);
+    (void)pcie_capability_read_word(pdev, PCI_EXP_LNKSTA, &gpu_lnksta);
+    gpu_aer_pos = pci_find_ext_capability(pdev, PCI_EXT_CAP_ID_ERR);
+    if (gpu_aer_pos)
+    {
+        (void)pci_read_config_dword(pdev, gpu_aer_pos + PCI_ERR_UNCOR_STATUS, &gpu_aer_unc);
+        (void)pci_read_config_dword(pdev, gpu_aer_pos + PCI_ERR_COR_STATUS,   &gpu_aer_cor);
+    }
+    if (parent)
+    {
+        (void)pcie_capability_read_word(parent, PCI_EXP_LNKSTA, &br_lnksta);
+        br_aer_pos = pci_find_ext_capability(parent, PCI_EXT_CAP_ID_ERR);
+        if (br_aer_pos)
+        {
+            (void)pci_read_config_dword(parent, br_aer_pos + PCI_ERR_UNCOR_STATUS, &br_aer_unc);
+            (void)pci_read_config_dword(parent, br_aer_pos + PCI_ERR_COR_STATUS,   &br_aer_cor);
+        }
+    }
+
+    nv_printf(NV_DBG_ERRORS,
+        "tb_egpu [UVM-DIAG]: site=%-18s pdev=%s bar0=0x%llx "
+        "PMC_BOOT_0=%s%08x WPR2=%s%08x WPR2_up=%s parent=%s "
+        "GPU_LnkSta=0x%04x(Speed=%u Width=x%u Active=%c) "
+        "Br_LnkSta=0x%04x(Speed=%u Width=x%u Active=%c) "
+        "GPU_AER_Unc=0x%08x Cor=0x%08x Br_AER_Unc=0x%08x Cor=0x%08x\n",
+        site, pci_name(pdev),
+        (unsigned long long)bar0_phys,
+        pmc_ok ? "0x" : "MAPFAIL:", pmc_boot_0,
+        (wpr2_rc == 0) ? "0x" : "MAPFAIL:", wpr2_raw,
+        ((wpr2_raw & TB_EGPU_RECOVER_WPR2_VAL_MASK) != 0) ? "YES" : "no",
+        parent ? pci_name(parent) : "NULL",
+        gpu_lnksta,
+        (gpu_lnksta & PCI_EXP_LNKSTA_CLS),
+        (gpu_lnksta & PCI_EXP_LNKSTA_NLW) >> 4,
+        (gpu_lnksta & PCI_EXP_LNKSTA_DLLLA) ? 'Y' : 'N',
+        br_lnksta,
+        (br_lnksta & PCI_EXP_LNKSTA_CLS),
+        (br_lnksta & PCI_EXP_LNKSTA_NLW) >> 4,
+        (br_lnksta & PCI_EXP_LNKSTA_DLLLA) ? 'Y' : 'N',
+        gpu_aer_unc, gpu_aer_cor, br_aer_unc, br_aer_cor);
+
+    (void)gpu_aer_pos; (void)br_aer_pos;
+}
+EXPORT_SYMBOL_GPL(tb_egpu_close_diag_pdev);
+
+void tb_egpu_close_diag(nv_linux_state_t *nvl,
+                        const char *site,
+                        long usage_count,
+                        bool is_last_close)
+{
+    nv_state_t *nv;
+
+    if (!nvl)
+        return;
+
+    nv = NV_STATE_PTR(nvl);
+
+    NV_DEV_PRINTF(NV_DBG_ERRORS, nv,
+        "tb_egpu [CLOSE]: site=%-15s usage_count=%ld%s\n",
+        site, usage_count, is_last_close ? " (LAST-CLOSE)" : "");
+
+    if (is_last_close && nvl->pci_dev)
+    {
+        /*
+         * Full state capture via the pdev-based variant — same passive
+         * capture both the RM-side and UVM-side close paths use. Diff
+         * across open->close->reopen tells us what the close path
+         * mutates in hardware/firmware state that breaks the next open.
+         */
+        tb_egpu_close_diag_pdev(nvl->pci_dev, site);
+        tb_egpu_dump_aer_trigger_event(nvl->pci_dev, site, NULL);
+    }
+}
