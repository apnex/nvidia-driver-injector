+++ b/kernel-open/nvidia/nv-tb-egpu-recover.c
@@ -402,6 +402,7 @@ void tb_egpu_dump_aer_trigger_event(struct pci_dev *gpu_pdev,
     }
     (void)gpu_aer_pos; (void)br_aer_pos; (void)root_aer_pos;
 }
