+/*
+ * Close-path observability surface (cluster P4).
+ *
+ * Companion to the open-side DIAG infrastructure (probe-end /
+ * startdev-entry / pre-rmInit / post-rmInit-{OK,FAIL}). Captures state
+ * diff across the open -> work -> close -> reopen lifecycle so the
+ * close-path bug class (docs/architecture.md Problem 2 + Problem 4)
+ * can be diagnosed empirically. Mitigation is currently observational
+ * — these markers are how we know the bug class stays mitigated under
+ * stack changes.
+ *
+ * tb_egpu_close_diag — RM-side marker.
+ *   site         short site label (e.g. "close-entry", "post-shutdown")
+ *   usage_count  caller's snapshot of nvl->usage_count at the site
+ *   is_last_close  caller-determined; true triggers full pdev-based
+ *                  DIAG + AER snapshot via tb_egpu_close_diag_pdev.
+ *                  False emits only the one-line marker.
+ *
+ * tb_egpu_close_diag_pdev — pdev-based passive state capture.
+ *   Reads PMC_BOOT_0 + WPR2 + LnkSta + AER (GPU + bridge) via
+ *   ioremap+ioread32 + PCI config-space reads only. No DMA, no
+ *   register writes. Called from tb_egpu_close_diag on last-close and
+ *   from the UVM-side close-path helpers (which use it cross-module).
+ *
+ * tb_egpu_get_gpu_pdev — exported lookup helper for cross-module
+ *   callers (UVM specifically). Walks nv_linux_devices under the
+ *   global lock and returns the first NVIDIA pdev with refcount
+ *   incremented (caller MUST pci_dev_put). Returns NULL if no
+ *   nvidia.ko-managed device is bound.
+ *
+ * Passive instrumentation pattern verified non-perturbing 2026-05-08
+ * (per memory project_close_path_mitigated_2026_05_08).
+ */
+void tb_egpu_close_diag(nv_linux_state_t *nvl,
+                        const char *site,
+                        long usage_count,
+                        bool is_last_close);
+void tb_egpu_close_diag_pdev(struct pci_dev *pdev, const char *site);
+struct pci_dev *tb_egpu_get_gpu_pdev(void);
+
 #endif /* _NV_TB_EGPU_RECOVER_H_ */
