# 79-nvidia-driver-injector.rules
#
# /dev/nvidia* device file group + permissions, applied by udev at
# module-load time (belt-and-suspenders alongside the NVreg_DeviceFile*
# options in /etc/modprobe.d/nvidia-driver-injector.conf).
#
# NVreg_DeviceFile* covers the main nvidia module's devices
# (/dev/nvidia0, /dev/nvidiactl). The nvidia_uvm sub-module has no
# equivalent NVreg_* parameter, so /dev/nvidia-uvm and
# /dev/nvidia-uvm-tools rely on this udev rule for their group
# permissions (or fall back to 0666 root:root, which is wide-open
# but safe given the ICD-disable posture).

KERNEL=="nvidia",            GROUP="gpu", MODE="0660"
KERNEL=="nvidiactl",         GROUP="gpu", MODE="0660"
KERNEL=="nvidia[0-9]*",      GROUP="gpu", MODE="0660"
KERNEL=="nvidia-uvm",        GROUP="gpu", MODE="0660"
KERNEL=="nvidia-uvm-tools",  GROUP="gpu", MODE="0660"
